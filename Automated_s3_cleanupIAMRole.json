{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "AllowListingOnlyTheAssignmentBucket",
			"Effect": "Allow",
			"Action": [
				"s3:ListBucket"
			],
			"Resource": [
				"arn:aws:s3:::basavaraj-aws-assignment1-s3-cleanup-2026"
			]
		},
		{
			"Sid": "AllowDeletingObjectsOnlyFromTheAssignmentBucket",
			"Effect": "Allow",
			"Action": [
				"s3:DeleteObject"
			],
			"Resource": [
				"arn:aws:s3:::basavaraj-aws-assignment1-s3-cleanup-2026/*"
			]
		}
	]
}